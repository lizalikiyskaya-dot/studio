// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  MENTOR
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  IN_PROGRESS
  SUBMITTED
  NEEDS_REVISION
  ACCEPTED
}

enum SynopsisMode {
  TEXT
  LINK
}

enum MaterialStatus {
  UNREAD
  IN_PROGRESS
  READ
}

enum MaterialCategory {
  BOOK
  HANDOUT
}

enum ArcType {
  POSITIVE
  NEGATIVE
  FLAT
}

enum FreeSectionType {
  TEXT
  TABLE
}

// Generic mentor-edit suggestion for a single field on any record.
// When a mentor edits a field that the student already filled in,
// the new text is stored here instead of overwriting the field, so
// the student can review and accept it.
model FieldSuggestion {
  id        String   @id @default(cuid())
  model     String
  recordId  String
  field     String
  value     String
  createdAt DateTime @default(now())

  @@unique([model, recordId, field])
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(STUDENT)
  status       UserStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  books        Book[]
  tasks        Task[]
  materials    Material[]
  drafts       Draft[]
  popArcCharacters  PopArcCharacter[]
  beliefCards       BeliefCard[]
  customExercises   CustomExercise[]
  freeSections      FreeSection[]
}

model Material {
  id        String           @id @default(cuid())
  studentId String
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int              @default(0)
  category  MaterialCategory @default(BOOK)
  title     String           @default("")
  status    MaterialStatus   @default(UNREAD)
  pdfUrl    String?
  pdfName   String?
  epubUrl   String?
  epubName  String?
  fileUrl   String?
  fileName  String?
}

model Draft {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  title     String   @default("")
  note      String   @default("")
  link      String?
  fileName  String?
  fileData  String?
  createdAt DateTime @default(now())
}

model PopArcCharacter {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  name      String   @default("")
  photoUrl  String?
  data      Json     @default("{}")
  isExample Boolean  @default(false)
}

model BeliefCard {
  id           String  @id @default(cuid())
  studentId    String
  student      User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order        Int     @default(0)
  hero         String  @default("")
  startBelief  String  @default("")
  endBelief    String  @default("")
  isExample    Boolean @default(false)
}

model CustomExercise {
  id               String            @id @default(cuid())
  studentId        String
  student          User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order            Int               @default(0)
  task             String            @default("")
  answer           String            @default("")
  answerSuggested  String?
  status           TaskStatus        @default(IN_PROGRESS)
  comments         ExerciseComment[]
}

model ExerciseComment {
  id         String         @id @default(cuid())
  exerciseId String
  exercise   CustomExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  author     String         @default("")
  text       String         @default("")
  createdAt  DateTime       @default(now())
}

model FreeSection {
  id        String          @id @default(cuid())
  studentId String
  student   User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int             @default(0)
  type      FreeSectionType @default(TEXT)
  title     String          @default("")
  content   String          @default("")
  tableData Json?
}

model Task {
  id           String     @id @default(cuid())
  title        String     @default("")
  workLink     String?
  feedbackLink String?
  status       TaskStatus @default(IN_PROGRESS)
  order        Int        @default(0)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Book {
  id        String   @id @default(cuid())
  title     String   @default("")
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  genre            String @default("")
  references       String @default("")
  audience         String @default("")
  partsCount       String @default("")
  timeStructure    String @default("")
  mainCharacters   String @default("")
  dramaticArgument String @default("")
  logline          String @default("")
  concept          String @default("")
  annotation       String @default("")
  coverUrl         String?

  synopsisMode SynopsisMode @default(TEXT)
  synopsisText String       @default("")
  synopsisLink String       @default("")

  grapesGeography    String @default("")
  grapesReligion      String @default("")
  grapesAchievements String @default("")
  grapesPolitics      String @default("")
  grapesEconomy       String @default("")
  grapesSocial        String @default("")
  settingPhotoUrl     String?
  settingChips        String[] @default([])

  chapters   PlanChapter[]
  characters Character[]
  acts       Act[]
  storylines Storyline[]
}

model PlanChapter {
  id               String @id @default(cuid())
  bookId           String
  book             Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order             Int    @default(0)
  summary          String @default("")
  dramaticArgument String @default("")
  images           String @default("")
  note             String @default("")
  plannedChars     Int    @default(0)
  writtenChars     Int    @default(0)
}

model Character {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  name      String   @default("")
  photoUrl  String?
  data      Json     @default("{}")
  arcType   ArcType?
  createdAt DateTime @default(now())
}

model Act {
  id       String @id @default(cuid())
  bookId   String
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order    Int    @default(0)
  title    String @default("")
  subtitle String @default("")
  content  String @default("")
}

model Storyline {
  id       String @id @default(cuid())
  bookId   String
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order    Int    @default(0)
  name     String @default("")
  chapters String @default("")
  status   String @default("")
  color    String?
}
