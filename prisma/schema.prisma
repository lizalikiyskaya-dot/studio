// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  MENTOR
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  IN_PROGRESS
  SUBMITTED
  NEEDS_REVISION
  ACCEPTED
}

enum SynopsisMode {
  TEXT
  LINK
}

enum MaterialStatus {
  UNREAD
  IN_PROGRESS
  READ
}

enum MaterialCategory {
  BOOK
  HANDOUT
}

enum ArcType {
  POSITIVE
  DISILLUSIONMENT
  FALL
  CORRUPTION
  FLAT
}

enum FreeSectionType {
  TEXT
  TABLE
}

enum PaymentStatus {
  PAID
  PENDING
}

enum WorldCategory {
  LOCATIONS
  FACTIONS
  LORE
  TECHNOLOGY
  MAGIC
  HISTORY
  CREATURES
  LANGUAGES
}

enum CharacterSource {
  SHARED
  OWN
}

enum SettingSource {
  SHARED
  OWN
}

// Generic comment thread attachable to any record (used in Упражнения).
model Comment {
  id        String   @id @default(cuid())
  model     String
  recordId  String
  field     String?
  author    String
  text      String
  createdAt DateTime @default(now())
}

// Generic mentor-edit suggestion for a single field on any record.
// When a mentor edits a field that the student already filled in,
// the new text is stored here instead of overwriting the field, so
// the student can review and accept it.
model FieldSuggestion {
  id        String   @id @default(cuid())
  model     String
  recordId  String
  field     String
  value     String
  createdAt DateTime @default(now())

  @@unique([model, recordId, field])
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  passwordHash  String
  role          UserRole      @default(STUDENT)
  status        UserStatus    @default(PENDING)
  paymentDay    Int?
  paymentStatus PaymentStatus @default(PENDING)
  reviewModeEnabled Boolean   @default(true)
  storyWorkshopUnlocked Boolean @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  books        Book[]
  tasks        Task[]
  materials    Material[]
  drafts       Draft[]
  popArcCharacters  PopArcCharacter[]
  beliefCards       BeliefCard[]
  storyCircleCards  StoryCircleCard[]
  customExercises   CustomExercise[]
  freeSections      FreeSection[]
  notes             Note[]
  cycles            Cycle[]
}

model Note {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  author    String   @default("")
  text      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Material {
  id        String           @id @default(cuid())
  studentId String
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int              @default(0)
  category  MaterialCategory @default(BOOK)
  title     String           @default("")
  status    MaterialStatus   @default(UNREAD)
  pdfUrl    String?
  pdfName   String?
  epubUrl   String?
  epubName  String?
  fileUrl   String?
  fileName  String?
}

model Draft {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  title     String   @default("")
  note      String   @default("")
  link      String?
  fileName  String?
  fileData  String?
  createdAt DateTime @default(now())
}

model PopArcCharacter {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  name      String   @default("")
  photoUrl  String?
  data      Json     @default("{}")
  arcType   ArcType?
  isExample Boolean  @default(false)
}

model BeliefCard {
  id           String  @id @default(cuid())
  studentId    String
  student      User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order        Int     @default(0)
  hero         String  @default("")
  startBelief  String  @default("")
  endBelief    String  @default("")
  isExample    Boolean @default(false)
}

model StoryCircleCard {
  id        String  @id @default(cuid())
  studentId String
  student   User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
  hero      String  @default("")
  data      Json    @default("{}")
  isExample Boolean @default(false)
}

model CustomExercise {
  id               String            @id @default(cuid())
  studentId        String
  student          User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order            Int               @default(0)
  task             String            @default("")
  answer           String            @default("")
  answerSuggested  String?
  status           TaskStatus        @default(IN_PROGRESS)
  comments         ExerciseComment[]
}

model ExerciseComment {
  id         String         @id @default(cuid())
  exerciseId String
  exercise   CustomExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  author     String         @default("")
  text       String         @default("")
  createdAt  DateTime       @default(now())
}

model FreeSection {
  id        String          @id @default(cuid())
  studentId String
  student   User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  order     Int             @default(0)
  type      FreeSectionType @default(TEXT)
  title     String          @default("")
  content   String          @default("")
  tableData Json?
  status    TaskStatus      @default(IN_PROGRESS)
}

model Task {
  id           String     @id @default(cuid())
  title        String     @default("")
  workLink     String?
  feedbackLink String?
  notes        String     @default("")
  status       TaskStatus @default(IN_PROGRESS)
  order        Int        @default(0)
  deadline     DateTime?
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Book {
  id        String   @id @default(cuid())
  title     String   @default("")
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  genre            String @default("")
  references       String @default("")
  audience         String @default("")
  partsCount       String @default("")
  timeStructure    String @default("")
  mainCharacters   String @default("")
  dramaticArgument String @default("")
  logline          String @default("")
  concept          String @default("")
  annotation       String @default("")
  coverUrl         String?

  synopsisMode SynopsisMode @default(TEXT)
  synopsisText String       @default("")
  synopsisLink String       @default("")

  grapesGeography    String @default("")
  grapesReligion      String @default("")
  grapesAchievements String @default("")
  grapesPolitics      String @default("")
  grapesEconomy       String @default("")
  grapesSocial        String @default("")
  settingPhotoUrl     String?
  settingChips        String[] @default([])

  fantasyUnlocked Boolean @default(false)
  fantasyNotes    String  @default("")
  fantasyGeneral  String  @default("")

  chapters     PlanChapter[]
  characters   Character[]
  acts         Act[]
  worldEntries WorldEntry[]
}

model PlanChapter {
  id               String @id @default(cuid())
  bookId           String
  book             Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order             Int    @default(0)
  summary          String @default("")
  dramaticArgument String @default("")
  images           String @default("")
  note             String @default("")
  plannedChars     Int    @default(0)
  writtenChars     Int    @default(0)
}

model Character {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  name      String   @default("")
  photoUrl  String?
  data      Json     @default("{}")
  arcType   ArcType?
  createdAt DateTime @default(now())
}

model WorldEntry {
  id        String        @id @default(cuid())
  bookId    String
  book      Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category  WorldCategory
  order     Int           @default(0)
  title     String        @default("Новая запись")
  body      String        @default("")
  photoUrl  String?
  createdAt DateTime      @default(now())
}

model Act {
  id       String       @id @default(cuid())
  bookId   String
  book     Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order    Int          @default(0)
  title    String       @default("")
  subtitle String       @default("")
  content  String       @default("")
  chapters ActChapter[]
}

model ActChapter {
  id          String           @id @default(cuid())
  actId       String
  act         Act              @relation(fields: [actId], references: [id], onDelete: Cascade)
  order       Int              @default(0)
  title       String           @default("")
  description String           @default("")
  blocks      StorylineBlock[]
}

model StorylineBlock {
  id          String     @id @default(cuid())
  chapterId   String
  chapter     ActChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  order       Int        @default(0)
  color       String     @default("pink")
  name        String     @default("")
  description String     @default("")
}

model Cycle {
  id        String   @id @default(cuid())
  title     String   @default("")
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  genre      String  @default("")
  concept    String  @default("")
  annotation String  @default("")
  coverUrl   String?

  stories      Story[]
  characters   CycleCharacter[]
  worldEntries CycleWorldEntry[]
}

model Story {
  id        String   @id @default(cuid())
  cycleId   String
  cycle     Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  title     String   @default("Новый рассказ")
  createdAt DateTime @default(now())

  setupText         String @default("")
  climaxText        String @default("")
  resolutionText    String @default("")
  characterPathText String @default("")

  characterSource CharacterSource @default(SHARED)
  settingSource   SettingSource   @default(SHARED)

  characters   StoryCharacter[]
  worldEntries StoryWorldEntry[]
}

model CycleCharacter {
  id        String   @id @default(cuid())
  cycleId   String
  cycle     Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  name      String   @default("")
  photoUrl  String?
  data      Json     @default("{}")
  arcType   ArcType?
  createdAt DateTime @default(now())
}

model StoryCharacter {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  name      String   @default("")
  photoUrl  String?
  data      Json     @default("{}")
  arcType   ArcType?
  createdAt DateTime @default(now())
}

model CycleWorldEntry {
  id        String        @id @default(cuid())
  cycleId   String
  cycle     Cycle         @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  category  WorldCategory
  order     Int           @default(0)
  title     String        @default("Новая запись")
  body      String        @default("")
  photoUrl  String?
  createdAt DateTime      @default(now())
}

model StoryWorldEntry {
  id        String        @id @default(cuid())
  storyId   String
  story     Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  category  WorldCategory
  order     Int           @default(0)
  title     String        @default("Новая запись")
  body      String        @default("")
  photoUrl  String?
  createdAt DateTime      @default(now())
}
